# Required for the hosted LLM.
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Optional. If missing or unreachable, the app runs with in-memory chat and memory storage.
DATABASE_URL=postgresql://user:password@host:5432/chatbot?sslmode=require

# Optional model settings.
HF_REPO_ID=Qwen/Qwen2.5-7B-Instruct
HF_MAX_TOKENS=2048
HF_TEMPERATURE=0.8
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional tool API keys. Tools return a friendly error if these are missing.
ALPHA_VINTAGE_KEY=
WEATHER_API_KEY=

# Optional app default.
LTM_USER_ID=u1
COOKIE_SECRET=change-me-cookie-secret
